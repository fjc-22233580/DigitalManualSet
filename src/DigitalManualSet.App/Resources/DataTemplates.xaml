<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:DigitalManualSet.App.ViewModels"
    xmlns:views="clr-namespace:DigitalManualSet.App.Views">

    <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
        <views:HomeView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:CreatePackageViewModel}">
        <views:CreatePackageView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:OpenPackageViewModel}">
        <views:OpenPackageView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <views:SettingsView />
    </DataTemplate>

</ResourceDictionary>