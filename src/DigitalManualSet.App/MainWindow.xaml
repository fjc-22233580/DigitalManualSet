<Window
    x:Class="App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:DigitalManualSet.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:DigitalManualSet.App.ViewModels"
    Title="{x:Static app:AppInfo.ProductName}"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance viewModels:ShellViewModel}"
    mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="4"
            BorderBrush="{DynamicResource ExpanderHeaderBorderBrush}"
            BorderThickness="{StaticResource ExpanderBorderThemeThickness}"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}">


            <StackPanel Orientation="Horizontal">

                <Button
                    Width="36"
                    Height="36"
                    Margin="8,0,0,0"
                    Padding="0"
                    Command="{Binding HomeCommand}"
                    IsEnabled="True"
                    ToolTip="Home">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="20"
                        Text="&#xE80F;" />
                </Button>

                <TextBlock
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="{Binding CurrentScreen.Title}" />
            </StackPanel>


        </Border>



        <Border
            Grid.Row="1"
            Margin="4"
            BorderBrush="{DynamicResource ExpanderHeaderBorderBrush}"
            BorderThickness="{StaticResource ExpanderBorderThemeThickness}"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}">

            <ContentControl Content="{Binding CurrentScreen.ViewModel}" />
        </Border>

    </Grid>
</Window>
